{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ticket_id",
    "category",
    "priority",
    "route",
    "customer_sentiment",
    "sla_minutes",
    "requires_human",
    "evidence_signals",
    "response_plan",
    "policy_version",
    "reason"
  ],
  "properties": {
    "ticket_id": {
      "type": "string",
      "pattern": "^SUP-[0-9]{5}$",
      "description": "Stable support ticket identifier"
    },
    "category": {
      "type": "string",
      "enum": ["ACCOUNT_ACCESS", "BILLING", "TECHNICAL", "SECURITY", "PRIVACY", "FEATURE_REQUEST"]
    },
    "priority": {
      "type": "string",
      "enum": ["P1", "P2", "P3", "P4"]
    },
    "route": {
      "type": "string",
      "enum": [
        "SELF_SERVE",
        "L1_SUPPORT",
        "SPECIALIST_QUEUE",
        "SECURITY_ESCALATION",
        "PRIVACY_ESCALATION",
        "ENGINEERING_ESCALATION"
      ]
    },
    "customer_sentiment": {
      "type": "string",
      "enum": ["CALM", "FRUSTRATED", "ANGRY", "DISTRESSED"]
    },
    "sla_minutes": {
      "type": "integer",
      "minimum": 15,
      "maximum": 2880
    },
    "requires_human": {
      "type": "boolean"
    },
    "evidence_signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signal", "severity", "quote"],
        "properties": {
          "signal": {
            "type": "string",
            "minLength": 3,
            "maxLength": 60
          },
          "severity": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
          },
          "quote": {
            "type": "string",
            "minLength": 3,
            "maxLength": 180
          }
        }
      }
    },
    "response_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_reply", "data_to_request", "safety_note"],
      "properties": {
        "first_reply": {
          "type": "string",
          "minLength": 12,
          "maxLength": 220
        },
        "data_to_request": {
          "type": "array",
          "maxItems": 4,
          "items": {"type": "string"}
        },
        "safety_note": {
          "type": "string",
          "minLength": 8,
          "maxLength": 180
        }
      }
    },
    "policy_version": {
      "type": "string",
      "const": "support-triage-v1"
    },
    "reason": {
      "type": "string",
      "minLength": 16,
      "maxLength": 260
    }
  }
}
