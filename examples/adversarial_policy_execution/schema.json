{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "decision",
    "risk_score",
    "policy_version",
    "allowed_actions",
    "blocked_actions",
    "evidence",
    "requires_human_review",
    "reason"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^ADV-[0-9]{3}$"
    },
    "decision": {
      "type": "string",
      "enum": ["ALLOW", "DENY", "ESCALATE"]
    },
    "risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "policy_version": {
      "type": "string",
      "const": "ape-v1"
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "target", "expires_minutes"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["READ", "SUMMARIZE", "NOTIFY", "REQUEST_INFO", "CREATE_TICKET"]
          },
          "target": {
            "type": "string",
            "minLength": 3,
            "maxLength": 80,
            "pattern": "^[A-Za-z0-9 ./_:@-]+$"
          },
          "expires_minutes": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1440
          }
        }
      }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "reason_code"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["DELETE", "EXFILTRATE", "PAY", "DISABLE_SECURITY", "RUN_SHELL", "REVEAL_SECRET"]
          },
          "reason_code": {
            "type": "string",
            "enum": ["UNAUTHORIZED", "PROMPT_INJECTION", "PII_RISK", "PAYMENT_RISK", "DESTRUCTIVE", "SECRET_RISK"]
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ids", "policy_citations", "confidence_notes"],
      "properties": {
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9-]{3,20}$"
          }
        },
        "policy_citations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "enum": ["AUTHZ-1", "DATA-2", "PAY-3", "OPS-4", "SEC-5"]
          }
        },
        "confidence_notes": {
          "type": "string",
          "minLength": 12,
          "maxLength": 180,
          "pattern": "^[A-Za-z0-9 .,;:_@/-]+$"
        }
      }
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "minLength": 20,
      "maxLength": 260,
      "pattern": "^[A-Za-z0-9 .,;:_@/-]+$"
    }
  }
}
