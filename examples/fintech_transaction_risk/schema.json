{
  "type": "object",
  "properties": {
    "transaction_id": {
      "type": "string",
      "pattern": "^TXN-[0-9]{5}$"
    },
    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "decision": {
      "type": "string",
      "enum": ["APPROVE", "STEP_UP_AUTH", "HOLD_REVIEW", "BLOCK"]
    },
    "risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "known_device",
              "velocity_spike",
              "new_payee",
              "geo_anomaly",
              "amount_anomaly",
              "sanctions_match",
              "account_takeover"
            ]
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 8,
            "maxLength": 180
          }
        },
        "required": ["name", "weight", "evidence"],
        "additionalProperties": false
      }
    },
    "controls": {
      "type": "object",
      "properties": {
        "requires_manual_review": {"type": "boolean"},
        "customer_message": {
          "type": "string",
          "enum": ["none", "verify_identity", "payment_delayed", "payment_blocked"]
        },
        "audit_channel": {
          "type": "string",
          "enum": ["risk-ledger", "fraud-review", "sanctions-escalation"]
        }
      },
      "required": ["requires_manual_review", "customer_message", "audit_channel"],
      "additionalProperties": false
    },
    "model_policy_version": {
      "const": "finrisk-v1"
    },
    "reason": {
      "type": "string",
      "minLength": 16,
      "maxLength": 260
    }
  },
  "required": [
    "transaction_id",
    "risk_level",
    "decision",
    "risk_score",
    "signals",
    "controls",
    "model_policy_version",
    "reason"
  ],
  "additionalProperties": false
}
